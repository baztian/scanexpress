[Unit]
Description=ScanExpress Flask Service
After=network.target

[Service]
Type=simple
User=scanexpress
Group=scanexpress
WorkingDirectory=/opt/scanexpress
EnvironmentFile=/etc/default/scanexpress
ExecStart=/opt/scanexpress/.venv/bin/python /opt/scanexpress/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
